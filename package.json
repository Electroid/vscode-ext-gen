{
  "name": "vscode-ext-gen",
  "type": "module",
  "version": "1.0.1",
  "packageManager": "bun@1.0.30",
  "description": "Generate TypeScript meta info for VS Code extension from package.json",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu/vscode-ext-gen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu/vscode-ext-gen.git"
  },
  "bugs": "https://github.com/antfu/vscode-ext-gen/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "bin": "./bin.mjs",
  "files": [
    "bin.mjs",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "prepublishOnly": "bun run build",
    "release": "bumpp && npm publish",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks && git submodule update --init --recursive"
  },
  "dependencies": {
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.14.0",
    "@antfu/utils": "^8.1.0",
    "@types/node": "^22.10.7",
    "bumpp": "^9.10.1",
    "eslint": "^9.18.0",
    "fast-glob": "^3.3.3",
    "lint-staged": "^15.4.1",
    "rimraf": "^6.0.1",
    "scule": "^1.3.0",
    "simple-git-hooks": "^2.11.1",
    "taze": "^18.2.0",
    "typescript": "^5.7.3",
    "unbuild": "^3.3.1",
    "vite": "^6.0.9",
    "vitest": "^3.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}